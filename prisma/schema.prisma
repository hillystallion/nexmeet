generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?
  image     String?
  code      String   @unique @default(cuid())
  role      String   @default("attendee")
  points    Int      @default(0)
  level     Int      @default(1)
  streak    Int      @default(0)
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendances Attendance[]
  ratings     Rating[]
  badges      Badge[]
}

model Host {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  organization String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  events Event[]
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   @default("Meeting")
  location    String?
  startTime   DateTime
  endTime     DateTime
  capacity    Int?
  featured    Boolean  @default(false)
  hostId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  host        Host         @relation(fields: [hostId], references: [id])
  attendances Attendance[]
  ratings     Rating[]
}

model Attendance {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  checkedIn DateTime @default(now())
  points    Int      @default(10)
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  score     Int
  comment   String?
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}

model Badge {
  id        String   @id @default(cuid())
  userId    String
  type      String
  name      String
  earnedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, type])
}
